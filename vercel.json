{
  "version": 2,
  "framework": "vite",

  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",

  "outputDirectory": "dist/spa",

  "functions": {
    "api/dose.ts": {
      "includeFiles": "dist/spa/index.html"
    }
  },

  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/dose/:slug",
      "destination": "/api/dose?slug=:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],

  "crons": [
    { "path": "/api/cron/daily-push", "schedule": "0 21 * * *" }
  ]
}
